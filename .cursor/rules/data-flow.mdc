# Data Flow Rules — Server Components & Server Actions

## Core Principles
1. **Reads** = Server Components (RSC) only
2. **Writes** (insert / update / delete) = Server Actions only
3. **Validation** = Zod schemas with TypeScript types — never raw FormData
4. **All DB access** = through helper functions in `src/db/queries/` — never inline queries

---

## Database Query Layer — `src/db/queries/`

All database reads and writes MUST be defined as helper functions in `src/db/queries/`. No server component or server action should import `db` directly or write inline Drizzle queries.

### File Structure
```
src/db/queries/
  decks.ts        # All deck-related queries and mutations
  cards.ts        # All card-related queries and mutations
  progress.ts     # All progress-related queries and mutations
  users.ts        # All user-related queries and mutations
  subscriptions.ts
```

One file per domain entity. Each file exports named functions for every query and mutation.

### Query Helper Rules
- Each function performs a single, focused DB operation
- Functions accept explicit parameters — never raw request objects
- Functions return typed results using Drizzle's inferred types
- No `SELECT *` — always select explicit columns
- Functions handle their own `isNull(table.deletedAt)` soft-delete filtering
- Use `React.cache()` wrappers for queries called in server components to deduplicate within a request

```ts
// CORRECT — src/db/queries/decks.ts
import { cache } from 'react'
import { db } from '@/db'
import { decks } from '@/db/schema'
import { eq, and, isNull } from 'drizzle-orm'

export const getDecksByUserId = cache(async (userId: string) => {
  return db.select({
    id: decks.id,
    title: decks.title,
    description: decks.description,
  }).from(decks).where(
    and(eq(decks.userId, userId), isNull(decks.deletedAt))
  )
})

export const getDeckById = cache(async (deckId: string, userId: string) => {
  const [deck] = await db.select({
    id: decks.id,
    title: decks.title,
    description: decks.description,
    userId: decks.userId
  }).from(decks).where(
    and(
      eq(decks.id, deckId),
      eq(decks.userId, userId),
      isNull(decks.deletedAt),
    )
  )
  return deck ?? null
})

export async function insertDeck(values: {
  userId: string
  title: string
  description: string | null
}) {
  const [newDeck] = await db.insert(decks).values(values).returning({
    id: decks.id,
    title: decks.title,
  })
  return newDeck
}

export async function updateDeckById(
  deckId: string,
  userId: string,
  values: { title?: string; description?: string | null },
) {
  const [updated] = await db.update(decks)
    .set({ ...values, updatedAt: new Date() })
    .where(
      and(eq(decks.id, deckId), eq(decks.userId, userId), isNull(decks.deletedAt))
    )
    .returning({ id: decks.id, title: decks.title })
  return updated ?? null
}

export async function softDeleteDeck(deckId: string, userId: string) {
  const [deleted] = await db.update(decks)
    .set({ deletedAt: new Date() })
    .where(
      and(eq(decks.id, deckId), eq(decks.userId, userId), isNull(decks.deletedAt))
    )
    .returning({ id: decks.id })
  return deleted ?? null
}
```

```ts
// WRONG — inline DB query in a server component
export default async function DecksPage() {
  const userDecks = await db.select({ ... }).from(decks).where(...) // NEVER do this
}

// WRONG — inline DB query in a server action
export async function createDeck(input: CreateDeckInput) {
  const [newDeck] = await db.insert(decks).values({ ... }) // NEVER do this
}

// WRONG — importing db directly in a server component or action
import { db } from '@/db' // Only db/queries files should import db
```

