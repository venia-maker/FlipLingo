# Data Flow Rules — Server Components & Server Actions

## Core Principles
1. **Reads** = Server Components (RSC) only
2. **Writes** (insert / update / delete) = Server Actions only
3. **Validation** = Zod schemas with TypeScript types — never raw FormData

---

## Data Retrieval — Server Components Only

All data fetching MUST happen in React Server Components. Never fetch data in client components.

```tsx
// CORRECT — fetch data in a server component
// app/decks/page.tsx (Server Component — no 'use client')
import { db } from '@/db'
import { decks } from '@/db/schema'
import { eq, isNull } from 'drizzle-orm'
import { createClient } from '@/lib/supabase/server'
import { redirect } from 'next/navigation'

export default async function DecksPage() {
  const supabase = await createClient()
  const { data, error } = await supabase.auth.getClaims()
  if (error || !data?.claims) redirect('/auth/login')

  const userId = data.claims.sub
  const userDecks = await db.select({
    id: decks.id,
    title: decks.title,
    description: decks.description,
  }).from(decks).where(
    and(eq(decks.userId, userId), isNull(decks.deletedAt))
  )

  return <DeckList decks={userDecks} />
}
```

```tsx
// WRONG — fetching data in a client component
'use client'
import { useEffect, useState } from 'react'

export function DeckList() {
  const [decks, setDecks] = useState([])
  useEffect(() => {
    fetch('/api/decks').then(res => res.json()).then(setDecks) // NEVER do this
  }, [])
}
```

### Rules
- No `fetch()` in client components for data retrieval
- No `useEffect` for loading data — use server components instead
- Pass fetched data as props to client components that need interactivity
- Use `React.cache()` to deduplicate repeated queries within a single request

---

## Mutations — Server Actions Only

All inserts, updates, and deletes MUST use server actions (`'use server'`).

### Server Action File Structure
Place server actions in colocated `actions.ts` files or in `src/app/_actions/`.

```ts
// CORRECT — server action with Zod validation and typed input
'use server'

import { z } from 'zod'
import { db } from '@/db'
import { decks } from '@/db/schema'
import { eq, and } from 'drizzle-orm'
import { createClient } from '@/lib/supabase/server'
import { redirect } from 'next/navigation'
import { revalidatePath } from 'next/cache'

const createDeckSchema = z.object({
  title: z.string().min(1).max(100),
  description: z.string().max(500).optional(),
})

type CreateDeckInput = z.infer<typeof createDeckSchema>

export async function createDeck(input: CreateDeckInput) {
  const validated = createDeckSchema.parse(input)

  const supabase = await createClient()
  const { data, error } = await supabase.auth.getClaims()
  if (error || !data?.claims) redirect('/auth/login')

  const userId = data.claims.sub

  const [newDeck] = await db.insert(decks).values({
    userId,
    title: validated.title,
    description: validated.description ?? null,
  }).returning({ id: decks.id, title: decks.title })

  revalidatePath('/decks')
  return newDeck
}
```

```tsx
// CORRECT — calling the server action from a client component
'use client'

import { createDeck } from './actions'

export function CreateDeckForm() {
  async function handleSubmit(e: React.FormEvent<HTMLFormElement>) {
    e.preventDefault()
    const title = titleRef.current?.value ?? ''
    const description = descRef.current?.value ?? ''

    // Pass a typed object — NOT FormData
    await createDeck({ title, description })
  }

  return <form onSubmit={handleSubmit}>...</form>
}
```

