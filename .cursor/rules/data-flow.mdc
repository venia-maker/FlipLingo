## Zod Validation — Mandatory for All Server Actions

### Every server action MUST:
1. Define a Zod schema for its input
2. Derive a TypeScript type from the schema using `z.infer<typeof schema>`
3. Use that type as the function parameter — never `FormData`
4. Call `.parse()` or `.safeParse()` on the input before any DB operation

```ts
// CORRECT — Zod schema + inferred type
const updateCardSchema = z.object({
  cardId: z.string().uuid(),
  front: z.string().min(1).max(500),
  back: z.string().min(1).max(500),
})

type UpdateCardInput = z.infer<typeof updateCardSchema>

export async function updateCard(input: UpdateCardInput) {
  const validated = updateCardSchema.parse(input)
  // ... perform update
}
```

```ts
// WRONG — using FormData as the type
export async function updateCard(formData: FormData) {
  const front = formData.get('front') as string // NEVER do this
  const back = formData.get('back') as string
}

// WRONG — no Zod validation
export async function updateCard(input: { front: string; back: string }) {
  await db.update(cards).set({ front: input.front }) // Unvalidated input
}

// WRONG — inline type instead of Zod-inferred
type UpdateCardInput = { front: string; back: string }
export async function updateCard(input: UpdateCardInput) { ... }
```

