## Client Component Pattern for Forms

When a client component needs to call a server action, extract form values into a typed object before calling.

```tsx
'use client'

import { updateDeck } from './actions'
import { useState } from 'react'

// Props come from a server component parent
interface EditDeckFormProps {
  deckId: string
  initialTitle: string
  initialDescription: string
}

export function EditDeckForm({ deckId, initialTitle, initialDescription }: EditDeckFormProps) {
  const [title, setTitle] = useState(initialTitle)
  const [description, setDescription] = useState(initialDescription)

  async function handleSave() {
    // Pass a typed object — never FormData
    await updateDeck({ deckId, title, description })
  }

  return (
    <div>
      <input value={title} onChange={(e) => setTitle(e.target.value)} />
      <textarea value={description} onChange={(e) => setDescription(e.target.value)} />
      <button onClick={handleSave}>Save</button>
    </div>
  )
}
```

